# Template — copiez en `environments/.env.development` et remplissez les valeurs.
# Mode développement local (npm run dev).

# URL du backend en local
VITE_API_BASE_URL=http://localhost:3000/api/v1/backoffice

# Clé API du backend (récupérée auprès de l'équipe back / dans le .env du serveur)
VITE_BACKOFFICE_API_KEY=your_backoffice_api_key_here

# Identifiants admin pour le formulaire de connexion du BO
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=changez-moi

# Affichage des outils de développement (TanStack Query DevTools, etc.)
VITE_DEV_TOOLS=true
