# Build production — API Render (préfixe backoffice identique au backend)
VITE_API_BASE_URL=https://quizzplus-api.onrender.com/api/v1/backoffice

# Secrets : NE PAS committer ici en clair.
# Définissez ces variables dans Vercel → Project Settings → Environment Variables (scope: Production).
# Localement, créez environments/.env.production.local pour les overrider (fichier ignoré).
VITE_BACKOFFICE_API_KEY=
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

VITE_DEV_TOOLS=false
