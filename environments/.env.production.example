# Template — à utiliser comme référence dans Vercel → Project Settings → Environment Variables (scope: Production).
# Ce fichier ne sert PAS au build Vercel ; les valeurs réelles doivent être configurées
# directement dans le dashboard Vercel (ou dans environments/.env.production en local, fichier ignoré).

# URL du backend de production
VITE_API_BASE_URL=https://quizzplus-api.onrender.com/api/v1/backoffice

# Clé API du backend (à régénérer si compromise)
VITE_BACKOFFICE_API_KEY=your_production_api_key_here

# Identifiants admin (à définir uniquement dans Vercel, jamais en clair ici)
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

VITE_DEV_TOOLS=false
