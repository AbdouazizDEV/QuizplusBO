# URL de base du backend NestJS Quizz+ (préfixée par /api/v1/backoffice côté front)
VITE_API_BASE_URL=http://localhost:3000/api/v1/backoffice

# Clé API admin du backoffice (gérée côté backend via header x-api-key)
# Injectée automatiquement sur chaque requête. Peut rester vide en local
# si le backend autorise le bypass (NODE_ENV != production sans BACKOFFICE_API_KEY).
VITE_BACKOFFICE_API_KEY=

# Identifiants d'accès à la console (login email/password côté UI)
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=changez-moi

# Active les outils dev (devtools React Query, logs)
VITE_DEV_TOOLS=true
